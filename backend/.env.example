# ============================================================
# backend/.env.example
# Copiar como .env y completar con los valores reales.
# NUNCA commitear el .env con valores reales.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://<project-id>.supabase.co

# Settings → API → Project API keys → anon / public
SUPABASE_ANON_KEY=sb_publishable_<anon-key>

# OPCIONAL — Solo necesario si tu proyecto usa el sistema Legacy HS256.
# Si tu proyecto tiene "JWT Signing Keys" con tipo ECC (P-256), dejá esta línea vacía
# o comentada. La validación se hace automáticamente via JWKS.
# Para verificar: Settings → Authentication → JWT Keys → si el CURRENT KEY es ECC, no necesitás esto.
# Si aún usás Legacy HS256: Settings → Authentication → JWT Keys → Legacy JWT Secret → "Reveal"
# SUPABASE_JWT_SECRET=

# Settings → API → Secret keys → default → ojo 👁 para revelar
# Usada SOLO para: crear usuarios (admin) + escribir audit_log (servidor)
# NUNCA exponer al cliente ni al repositorio
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<completar>

# ── App ──────────────────────────────────────────────────────
# Orígenes permitidos para CORS (separados por coma si hay varios)
# En desarrollo: http://localhost:5173
# En producción: https://app.idmsansalvador.com.ar
ALLOWED_ORIGINS=http://localhost:5173

# development → habilita /docs (Swagger UI)
# production  → deshabilita /docs
ENVIRONMENT=development
